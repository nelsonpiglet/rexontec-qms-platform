# ══════════════════════════════════════════════════════
# REXONTEC 力科品質指揮平台 — .gitignore
# ══════════════════════════════════════════════════════

# ── 敏感資料 / 金鑰（絕對不上傳）───────────────────
service_account.json
*service_account*.json
*service_account*.txt
project-*.json
*.json.key
*_credentials.json
*_serviceaccount*.json
*.pem
*.p12
.streamlit/secrets.toml

# ── 工具腳本（含金鑰轉換邏輯）───────────────────────
toml_convert.py

# ── Office 暫存檔 ──────────────────────────────────
~$*
*.docx
*.pptx
*.xlsx~

# ── Python cache ─────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.pyo
*.so
.Python

# ── 虛擬環境 ──────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
pythonenv*/
.pdm-python
.pdm-build/
.pixi
__pypackages__/

# ── 環境變數 ──────────────────────────────────────────
.env
.env.*
!.env.example
.envrc

# ── 打包 / 建置 ───────────────────────────────────────
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.spec
*.manifest

# ── 測試 / Coverage ────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ── 暫存 / 輸出 ────────────────────────────────────────
_tmp_ids.txt
*.tmp
*.log
*.bak
*.swp
*.pdf
*.xlsx
*.xls
tempCodeRunnerFile.py

# ── 系統 / OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 啟動批次檔（Windows 限定）────────────────────────
*.bat

# ── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
.spyderproject
.spyproject
.ropeproject
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/
.pypirc

# ── Jupyter ───────────────────────────────────────────
.ipynb_checkpoints
profile_default/
ipython_config.py

# ── 本地測試工具 ──────────────────────────────────────
ngrok*
*.ngrok*

# ── Streamlit Cloud（secrets 已上方排除）─────────────
# .streamlit/secrets.toml  ← 已在頂部宣告
